{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tnc/profile-cards-item",
	"version": "0.1.0",
	"title": "Profile Card",
	"category": "widgets",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {},
	"attributes": {
		"imageID": {
			"type": "number"
		},
		"imageURL": {
			"type": "string"
		},
		"name": {
			"type": "string"
		},
		"address": {
			"type": "string"
		},
		"telephone": {
			"type": "string"
		},
		"buttonLabel": {
			"type": "string"
		},
		"buttonUrl": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false
	},
	"parent": ["tnc/profile-cards"],
	"textdomain": "profile-cards-item",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
