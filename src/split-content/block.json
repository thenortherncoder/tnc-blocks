{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tnc/split-content",
	"version": "0.1.0",
	"title": "Split Content",
	"category": "tnc-blocks",
	"icon": "columns",
	"description": "A block that splits content into two columns, with a heading on one side and content on the other.",
	"example": {},
	"providesContext": {
		"tnc/isNested": "isNested"
	},
	"attributes": {
		"title": {
			"type": "string"
		},
		"isNested": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"color": {
			"background": true,
			"text": false
		}
	},
	"textdomain": "split-content",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
